{
  "version": 2,
  "builds": [
    { "src": "backend/api/index.js", "use": "@vercel/node" },
    { "src": "frontend-react/package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } },
    { "src": "frontend-angular/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist/fallamarket-angular" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/api/index.js" },

    { "src": "^/react(?:/(.*))?$", "dest": "/frontend-react/index.html" },
    { "src": "^/react/(.*)$", "dest": "/frontend-react/$1" },

    { "src": "^/angular(?:/(.*))?$", "dest": "/frontend-angular/index.html" },
    { "src": "^/angular/(.*)$", "dest": "/frontend-angular/$1" }
  ]
}
